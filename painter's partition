#include <iostream>
#include <vector>
using namespace std;

const long long MOD = 1000000007;

int main() {
    int n;
    long long L, R;

    cin >> n >> L >> R;

    vector<int> a(n + 1);
    vector<long long> prefix(n + 1, 0);

    for (int i = 1; i <= n; i++) {
        cin >> a[i];
        prefix[i] = prefix[i - 1] + a[i];
    }

    vector<long long> dp(n + 1, 0);
    dp[0] = 1;

    for (int i = 1; i <= n; i++) {

        for (int j = i; j >= 1; j--) {

            long long sum = prefix[i] - prefix[j - 1];

            if (sum > R)
                break;

            if (sum >= L && sum <= R) {
                dp[i] = (dp[i] + dp[j - 1]) % MOD;
            }
        }
    }

    cout << dp[n] % MOD;

    return 0;
}
